<Window x:Class="MuzikUSBYoneticisi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MuzikUSBYoneticisi"
        mc:Ignorable="d"
        Title="Müzik USB Yöneticisi V4" Height="680" Width="1050"
        WindowStartupLocation="CenterScreen" Background="Transparent" 
        WindowStyle="None" AllowsTransparency="True" FontFamily="Segoe UI">

    <!-- Ana Pencere -->
    <Border Background="#FF1E1E24" CornerRadius="12" BorderBrush="#FF2F3136" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="120"/>
            </Grid.RowDefinitions>

            <!-- 1. Üst Başlık -->
            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Margin="0,5,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Müzik USB Yöneticisi V4 - Premium Her Yerden İndirme" FontWeight="Bold" Foreground="#FF5E8EE4" Margin="20,10,10,5" FontSize="18"/>

                <Button Grid.Column="1" Content="✕" Click="CloseButton_Click" Background="Transparent" Foreground="#FFAAAAAA" BorderThickness="0" FontSize="18" Width="40" Height="40" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="CloseBorder" Background="{TemplateBinding Background}" CornerRadius="20">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CloseBorder" Property="Background" Value="#FF4C2525"/>
                                    <Setter Property="Foreground" Value="#FFFF5555"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Alt Başlık / Bilgi -->
            <TextBlock Grid.Row="1" Text="Teyp Uyumlu ID3 Etiketli İndirme | Akıllı PC İndirme | Playlist/Kanal Link Entegrasyonu" Foreground="#FFAAAAAA" Margin="20,0,10,15" FontSize="12"/>

            <!-- 2. Orta Kısım: İki Panel -->
            <Grid Grid.Row="2" Margin="20,0,20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.3*"/>
                </Grid.ColumnDefinitions>

                <!-- SOL PANEL: Arama & Playlist Bağlantısı -->
                <Border Grid.Column="0" Background="#FF222329" BorderBrush="#FF2F3136" BorderThickness="1" CornerRadius="12" Margin="0,0,10,0" Padding="15">
                    <StackPanel>
                        <!-- ADIM 1: HEDEF VE TÜR AYARLARI -->
                        <TextBlock Text="1. Hedef USB &amp; Arşiv Klasörü" Foreground="#FF5E8EE4" FontWeight="Bold" FontSize="15" Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Hedef USB:" Foreground="#FFBBBBBB" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            <Border Grid.Column="1" Background="#FF1A1A1F" BorderBrush="#FF10B981" BorderThickness="1.5" CornerRadius="6" Margin="0,0,5,0" Height="30">
                                    <ComboBox x:Name="UsbComboBox" ToolTip="Kopyalama yapılacak veya taranacak USB diski seçin." BorderThickness="0" Padding="5,0" Margin="2" Background="Transparent" Foreground="Black" VerticalContentAlignment="Center" SelectionChanged="UsbComboBox_SelectionChanged"/>
                                    </Border>
                                    <Button Grid.Column="2" Click="RefreshUsb_Click" Cursor="Hand" Width="60" ToolTip="USB sürücü listesini yeniler.">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="BtnBorder" Background="#FF0F766E" CornerRadius="6">
                                                    <TextBlock Text="Yenile" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="BtnBorder" Property="Background" Value="#FF059669"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>

                                <TextBlock Text="Bilgisayar İndirme Arşivi Yolu (Klasör):" Foreground="#FF999999" FontSize="11" Margin="0,0,0,5"/>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#FF1A1A1F" BorderBrush="#FF3A3A40" BorderThickness="1" CornerRadius="6,0,0,6" Height="30">
                                        <TextBox x:Name="ArchivePathTextBox" ToolTip="Tüm aramaların indirileceği ana PC klasörü" Background="Transparent" Foreground="#FFAAAAAA" BorderThickness="0" Padding="10,0" VerticalContentAlignment="Center" IsReadOnly="True" TextWrapping="NoWrap" FontSize="11"/>
                                    </Border>
                                    <Button Grid.Column="1" Click="ChangeFolderBtn_Click" Cursor="Hand" Width="70" ToolTip="İndirme klasörünü değiştirmek için tıklayın.">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="SettingsBtnBorder" Background="#FF333333" BorderBrush="#FF3A3A40" BorderThickness="0,1,1,1" CornerRadius="0,6,6,0">
                                                    <TextBlock Text="Değiştir" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="SettingsBtnBorder" Property="Background" Value="#FF4A4A4A"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>

                                <Border BorderBrush="#FF3A3A40" BorderThickness="0,0,0,1" Margin="0,0,0,15"/>

                                <!-- ADIM 2: ARAMA -->
                                <TextBlock Text="2. Akıllı Arama &amp; Kanal/Liste Tarama" Foreground="#FF5E8EE4" FontWeight="Bold" FontSize="15" Margin="0,0,0,10"/>

                                <TextBlock Text="Kelime, Youtube Linki veya Kanal Linki (@kanal):" Foreground="#FFBBBBBB" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,0,5" FontSize="12"/>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#FF1A1A1F" BorderBrush="#FF3A3A40" BorderThickness="1.5" CornerRadius="6" Height="40" Margin="0,0,5,0">
                                        <TextBox x:Name="UrlTextBox" ToolTip="Aramak istediğiniz sanatçıyı veya Youtube Linkini (video, playlist, kanal) buraya yapıştırıp aratın." FocusVisualStyle="{x:Null}" CaretBrush="#FF5E8EE4" Background="Transparent" Foreground="White" BorderThickness="0" Padding="10,0" FontSize="13" FontWeight="SemiBold" VerticalContentAlignment="Center" KeyDown="UrlTextBox_KeyDown"/>
                                    </Border>
                                    <Border Grid.Column="1" Background="#FF1A1A1F" BorderBrush="#FF3A3A40" BorderThickness="1.5" CornerRadius="6" Height="40" Width="80" ToolTip="Arama sonucunda getirilecek en fazla kayıt sayısı limitini belirleyin">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="Limit:" Foreground="#FF999999" FontSize="11" Margin="0,0,3,0" VerticalAlignment="Center"/>
                                            <TextBox x:Name="SearchLimitTextBox" Text="50" Foreground="White" Background="Transparent" BorderThickness="0" Width="35" FontSize="12" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Button Click="AddToListBtn_Click" Cursor="Hand" Height="35" ToolTip="Youtube üzerinde arama yapar ve eksik olanları indirilecekler listesine ekler.">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="SearchBtnBorder" Background="#FF3B82F6" CornerRadius="6">
                                        <TextBlock Text="Eksik Şarkıları Çek (Arama/Kanal/Liste)" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="SearchBtnBorder" Property="Background" Value="#FF2563EB"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- YENİ EKLENEN FİLTRE: REMİX / ORİJİNAL -->
                        <Border Background="#FF1A1A1F" BorderBrush="#FF3A3A40" BorderThickness="1" CornerRadius="6" Margin="0,15,0,0" Padding="10" ToolTip="Gereksiz versiyonları aradan çıkarmak için buradan filtreleyebilirsiniz.">
                            <StackPanel>
                                <TextBlock Text="Versiyon Filtresi (Remix / Orijinal):" Foreground="#FF999999" FontSize="11" Margin="0,0,0,5" FontWeight="SemiBold"/>
                                <ComboBox x:Name="FilterComboBox" BorderThickness="0" Background="#FFE6E6E6" Foreground="Black" Padding="5,2" SelectedIndex="0" Cursor="Hand" FocusVisualStyle="{x:Null}">
                                    <ComboBoxItem Content="Tüm Sonuçları Göster (Orijinal + Mix)"/>
                                    <ComboBoxItem Content="Sadece Orijinal Şarkılar (Remix/Mix Hariç)"/>
                                    <ComboBoxItem Content="Sadece Remix / Mix / Club Versiyonları"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- SAĞ PANEL: İndirme & USB'ye Eşitleme -->
                <Border Grid.Column="1" Background="#FF222329" BorderBrush="#FF2F3136" BorderThickness="1" CornerRadius="12" Margin="10,0,0,0" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="3. İndirme Listesi &amp; İşlemler" Foreground="#FF5E8EE4" FontWeight="Bold" FontSize="15" Margin="0,0,0,10"/>

                        <!-- Üst Araç Çubuğu -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                            <Button x:Name="SelectAllBtn" Content="Tümünü Seç" Click="SelectAllBtn_Click" Cursor="Hand" Margin="0,0,10,0" ToolTip="Tüm şarkıları seçer veya seçimi kaldırır.">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent" BorderBrush="#FF4A2222" BorderThickness="1" CornerRadius="6" Padding="10,6">
                                            <TextBlock Text="{TemplateBinding Content}" Foreground="LightGray" FontWeight="SemiBold" FontSize="12"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Click="ClearListBtn_Click" Cursor="Hand" Margin="0,0,10,0" ToolTip="Arama sonuçlarını siler (Arşivi silmez).">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent" BorderBrush="#FF4A2222" BorderThickness="1" CornerRadius="6" Padding="10,6">
                                            <TextBlock Text="Listeyi Boşalt" Foreground="LightGray" FontWeight="SemiBold" FontSize="12"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Click="CleanUsbBtn_Click" Cursor="Hand" Margin="0,0,10,0" ToolTip="Seçili USB içerisindeki bozuk, gizli ve teypte çalışmayan dosyaları temizler. (Önce onay sorar)">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent" BorderBrush="#FF4A2222" BorderThickness="1" CornerRadius="6" Padding="10,6">
                                            <TextBlock Text="Uyumsuz Dosyaları Sil" Foreground="#FFFF5555" FontWeight="SemiBold" FontSize="12"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <TextBlock x:Name="SelectionInfoText" Text="0 Seçili (~0 MB)" Foreground="#FFDfb911" VerticalAlignment="Center" Margin="5,0,0,0" FontWeight="SemiBold" FontSize="12"/>
                        </StackPanel>

                        <!-- Dinamik Canlı Liste (Fotoğraflı) -->
                        <Border Grid.Row="2" Background="#FF191A1E" BorderBrush="#FF2F3136" BorderThickness="1" CornerRadius="6" Margin="0,0,0,15">
                            <ListBox x:Name="SearchResultsListBox" AllowDrop="True" Drop="SearchResultsListBox_Drop" Background="Transparent" Foreground="#FFE6E6E6" BorderThickness="0" Padding="5" SelectionMode="Multiple" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="SearchResultsListBox_SelectionChanged">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" Margin="2" Padding="2">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="#FF29436A"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#FF26282E"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Margin="0,0,10,0" VerticalAlignment="Center"/>

                                            <!-- Küçük Kapak Fotoğrafı -->
                                            <Border Grid.Column="1" Width="50" Height="36" CornerRadius="4" Margin="0,0,10,0" BorderBrush="#FF3A3A40" BorderThickness="1">
                                                <Border.Background>
                                                    <ImageBrush ImageSource="{Binding ThumbnailUrl}" Stretch="UniformToFill" />
                                                </Border.Background>
                                            </Border>

                                            <!-- Metin ve İlerleme Çubuğu -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" FontSize="12"/>
                                                <TextBlock Text="{Binding Author}" Foreground="#FF888888" FontSize="10"/>

                                                <!-- Download İlerlemesi İçin Minik ProgressBar -->
                                                <ProgressBar Visibility="{Binding IsDownloading}" Minimum="0" Maximum="100" Value="{Binding ProgressValue}" Height="3" Margin="0,4,10,0" Foreground="#FF10B981" BorderThickness="0" Background="#FF333333"/>
                                            </StackPanel>

                                            <!-- Mini Player Butonu -->
                                            <Button Grid.Column="3" Content="▶" Width="30" Height="25" Margin="0,0,5,0" Cursor="Hand" ToolTip="Şarkıyı/İneni dinlemek için tıklayın." Foreground="#FF25C158" Background="Transparent" BorderThickness="0" CommandParameter="{Binding}" Click="PreviewBtn_Click"/>

                                            <TextBlock Grid.Column="4" Text="{Binding Duration}" Foreground="#FF888888" VerticalAlignment="Center" Margin="5,0,0,0" HorizontalAlignment="Right" FontSize="11"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <!-- Final İşlemleri Butonları (Daraltıldı) -->
                        <Grid Grid.Row="3" Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Click="DownloadBtn_Click" Cursor="Hand" Height="36" ToolTip="Listede seçili olan tüm şarkıları maksimum kalitede PC'nize indirip, FFmpeg ile sesini normalleştirir. (Aynı anda 3 müzik indirilir)">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="DlBtnBorder" Background="#FFEF4444" CornerRadius="6">
                                            <TextBlock Text="Arşive İndir (PC)" Foreground="White" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="DlBtnBorder" Property="Background" Value="#FFDC2626"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- YENİ EKLENEN BUTON: Akıllı Klasörleme Ayarı Toggles -->
                            <Button Grid.Column="2" Click="ToggleSmartFolderBtn_Click" Cursor="Hand" Height="36" ToolTip="Akıllı klasörleme yöntemini değiştirir. Sanatçıya göre klasör veya Hepsi tek yere atılır.">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="SmartBtnBorder" Background="#FF3B82F6" CornerRadius="6">
                                            <TextBlock x:Name="SmartBtnIcon" Text="Klasörleme: Açık" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="SmartBtnBorder" Property="Background" Value="#FF2563EB"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Grid.Column="4" Click="SyncBtn_Click" Cursor="Hand" Height="36" ToolTip="PC'deki arşiv klasörünüzü, hedef USB Diskinize otomatik olarak aktarır ve m3u oluşturur">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="SyncBtnBorder" Background="#FF10B981" CornerRadius="6">
                                            <TextBlock Text="USB'ye Kopyala" Foreground="White" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="SyncBtnBorder" Property="Background" Value="#FF059669"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- 3. Durum Çubuğu ve Copyright Bilgisi -->
            <Grid Grid.Row="3" Margin="20,0,20,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#FF222329" BorderBrush="#FF2F3136" BorderThickness="1" CornerRadius="8" Padding="15,8">
                    <TextBlock x:Name="StatusTextBlock" Text="Hazır" Foreground="#FF10B981" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis"/>
                </Border>
                <Border Grid.Column="1" Margin="10,0,0,0" ToolTip="Geliştirici Bilgileri" Background="Transparent" CornerRadius="8" Cursor="Hand" MouseLeftButtonDown="Copyright_MouseLeftButtonDown">
                    <TextBlock Text="© 2024 Developed by Cloud" Foreground="#FF555555" FontSize="11" VerticalAlignment="Center" FontWeight="SemiBold" Margin="5,0"/>
                </Border>
            </Grid>

            <!-- 4. Canlı Log -->
            <Border Grid.Row="4" Background="#FF191A1E" BorderBrush="#FF2F3136" BorderThickness="1" CornerRadius="8" Margin="20,5,20,15">
                <ListBox x:Name="LogListBox" Background="Transparent" Foreground="#FF999999" BorderThickness="0" Padding="10" FontSize="11" FontFamily="Consolas" ScrollViewer.HorizontalScrollBarVisibility="Disabled" IsTabStop="False" FocusVisualStyle="{x:Null}">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <!-- Log satırlarında mouse hover ve tıklama seçim rengini / mavi çizgiyi kapatıyoruz -->
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="IsTabStop" Value="False"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="Transparent" Padding="0,2">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel VerticalAlignment="Bottom"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
            </Border>
        </Grid>
    </Border>
</Window>
